{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Graph.Communications": "Debug"
    }
  },
  "AllowedHosts": "*",

  "Bot": {
    "TenantId": "YOUR_TENANT_ID",
    "AppId": "YOUR_APP_ID",
    "AppSecret": "YOUR_APP_SECRET",
    "NotificationUrl": "https://teamsbot.yourdomain.com/api/calling",
    "LocalHttpListenUrl": "https://0.0.0.0:9443",
    "LocalHttpListenPort": 9443
  },

  "MediaPlatformSettings": {
    "ApplicationId": "YOUR_APP_ID",
    "CertificateThumbprint": "YOUR_CERT_THUMBPRINT",
    "CertificateFriendlyName": "alfred-disney-cert",
    "InstanceInternalPort": 8445,
    "InstancePublicPort": 8445,
    "ServiceFqdn": "media.yourdomain.com",
    "InstancePublicIPAddress": "0.0.0.0"
  },

  "Stt": {
    "Provider": "Deepgram",
    "Deepgram": {
      "ApiKey": "YOUR_DEEPGRAM_API_KEY",
      "Model": "nova-3",
      "Diarize": true
    },
    "AzureSpeech": {
      "Key": "YOUR_AZURE_SPEECH_KEY",
      "Region": "eastus",
      "RecognitionLanguage": "en-US",
      "EndpointId": null
    }
  },

  "EventDispatch": {
    "BootstrapConsumerUrl": "https://agent.yourdomain.com/v2/events"
  },

  "BlobArchive": {
    "AccountUrl": "https://YOUR_STORAGE_ACCOUNT.blob.core.windows.net",
    "ContainerName": "alfred-events",
    "V1CompatEnabled": false,
    "V1CompatChannelIds": []
  },

  "MeetingChat": {
    "Enabled": false,
    "GraphNotificationBaseUrl": "https://teamsbot.yourdomain.com",
    "GraphSubscriptionEncryptionCertPath": null,
    "GraphSubscriptionEncryptionCertPassword": null,
    "GraphSubscriptionEncryptionCertId": null,
    "ChatSubscriptionClientStateSecret": "CHANGE_ME_OPAQUE_SECRET",
    "ChatSendMaxRps": 4.0,
    "TeamsAppCatalogId": null,
    "UseInstalledToChatsSubscription": true
  },

  "MicrosoftAppType": "SingleTenant",
  "MicrosoftAppId": "YOUR_APP_ID",
  "MicrosoftAppPassword": "YOUR_APP_SECRET",
  "MicrosoftAppTenantId": "YOUR_TENANT_ID",

  "JoinMode": {
    "PreferredMode": "invite_and_graph_join",
    "PolicyAutoInviteEnabled": false,
    "AutoFallbackToInviteAndGraphJoin": true,
    "RequireBotAttendeeForInviteJoin": true,
    "TenantOverrides": {
      "YOUR_TENANT_ID": {
        "PreferredMode": "invite_and_graph_join",
        "PolicyAutoInviteEnabled": false,
        "AutoFallbackToInviteAndGraphJoin": true,
        "RequireBotAttendeeForInviteJoin": true
      }
    }
  }
}

{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.21/MicrosoftTeams.schema.json",
  "manifestVersion": "1.21",
  "version": "1.0.9",
  "id": "ff4b0902-5ae8-450b-bf45-7e2338292554",
  "developer": {
    "name": "QMachina",
    "websiteUrl": "https://qmachina.com",
    "privacyUrl": "https://qmachina.com/privacy",
    "termsOfUseUrl": "https://qmachina.com/terms"
  },
  "name": {
    "short": "Alfred",
    "full": "Alfred — Meeting Assistant"
  },
  "description": {
    "short": "Active meeting assistant: live transcription, analysis, and chat I/O",
    "full": "Alfred joins Teams meetings, captures real-time diarized audio, reads and writes the meeting chat in real time, and surfaces a live AI-generated dossier in an external workspace."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#FFFFFF",
  "bots": [
    {
      "botId": "ff4b0902-5ae8-450b-bf45-7e2338292554",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "supportsCalling": true,
      "supportsVideo": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "teamsbot.qmachina.com",
    "media.qmachina.com",
    "qmachina.com"
  ],
  "webApplicationInfo": {
    "id": "ff4b0902-5ae8-450b-bf45-7e2338292554",
    "resource": "api://teamsbot.qmachina.com/ff4b0902-5ae8-450b-bf45-7e2338292554"
  },
  "configurableTabs": [
    {
      "configurationUrl": "https://teamsbot.qmachina.com/configure",
      "canUpdateConfiguration": true,
      "scopes": ["groupChat"],
      "context": ["meetingChatTab", "meetingDetailsTab", "meetingSidePanel"]
    }
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        { "name": "ChatMessage.Read.Chat", "type": "Application" },
        { "name": "ChatMessageReadReceipt.Read.Chat", "type": "Application" },
        { "name": "OnlineMeetingParticipant.Read.Chat", "type": "Application" },
        { "name": "Calls.AccessMedia.Chat", "type": "Application" },
        { "name": "Calls.JoinGroupCalls.Chat", "type": "Application" }
      ]
    }
  }
}

{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.21/MicrosoftTeams.schema.json",
  "manifestVersion": "1.21",
  "version": "1.0.4",
  "id": "e68b49d1-0aae-4761-a595-4df482d8d4fe",
  "packageName": "com.qmachina.alfred",
  "developer": {
    "name": "QMachina",
    "websiteUrl": "https://qmachina.com",
    "privacyUrl": "https://qmachina.com/privacy",
    "termsOfUseUrl": "https://qmachina.com/terms"
  },
  "name": {
    "short": "Alfred",
    "full": "Alfred — Meeting Assistant"
  },
  "description": {
    "short": "Passive meeting assistant: live transcription + chat I/O",
    "full": "Alfred joins Teams meetings, captures real-time diarized audio, reads and writes the meeting chat, and surfaces live notes and summaries in an external workspace."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#FFFFFF",
  "bots": [
    {
      "botId": "e68b49d1-0aae-4761-a595-4df482d8d4fe",
      "scopes": ["personal", "team", "groupchat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "supportsCalling": true,
      "supportsVideo": false
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "validDomains": [
    "teamsbot.qmachina.com",
    "media.qmachina.com",
    "qmachina.com"
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://teamsbot.qmachina.com/configure",
      "canUpdateConfiguration": true,
      "scopes": ["groupchat"],
      "context": ["meetingChatTab", "meetingDetailsTab", "meetingSidePanel"]
    }
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        { "name": "ChatMessage.Read.Chat", "type": "Application" },
        { "name": "ChatMessageReadReceipt.Read.Chat", "type": "Application" },
        { "name": "OnlineMeetingParticipant.Read.Chat", "type": "Application" },
        { "name": "OnlineMeeting.ReadBasic.Chat", "type": "Application" },
        { "name": "Calls.AccessMedia.Chat", "type": "Application" },
        { "name": "Calls.JoinGroupCalls.Chat", "type": "Application" },
        { "name": "TeamsActivity.Send.Chat", "type": "Application" }
      ]
    }
  }
}
